package com.springboot.rocky.controller;

// 1. 다른 패키지에 있는 클래스를 사용하기 위한 Import 문 (매우 중요!)
import com.springboot.rocky.dto.CodeRequest;
import com.springboot.rocky.service.DockerService;

import lombok.RequiredArgsConstructor;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RequestBody;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RestController;

@RestController
@RequestMapping("/api/v1/build")
@RequiredArgsConstructor // 생성자 주입을 통해 DockerService를 가져옵니다.
public class BuildController {

    // 2. 서비스 객체 선언 (final 필수)
    private final DockerService dockerService;

    /**
     * 사용자의 코드를 받아 Rocky Linux 컨테이너에서 실행합니다.
     */
    @PostMapping("/run")
    public String runBuild(@RequestBody CodeRequest request) {
        
        // 유효성 검사: 사용자 ID가 없으면 실행 거부
        if (request.getUserId() == null || request.getUserId().isEmpty()) {
            return "Error: User ID is required.";
        }

        // DockerService의 run 메서드를 호출 (userId, language, code 전달)
        return dockerService.run(
            request.getUserId(), 
            request.getLanguage(), 
            request.getCode()
        );
    }
}