package com.springboot.rocky.controller;

import com.springboot.rocky.dto.CodeRequest;
import com.springboot.rocky.dto.BuildResponse;
import com.springboot.rocky.service.DockerService;

import lombok.RequiredArgsConstructor;
import org.springframework.web.bind.annotation.*;

@RestController
@RequestMapping("/api/v1/build")
@RequiredArgsConstructor // DockerService 주입을 위한 생성자 자동 생성
public class BuildController {

    private final DockerService dockerService;

    /**
     * 사용자의 코드 실행 요청을 처리합니다.
     */
    @PostMapping("/run")
    public BuildResponse runBuild(@RequestBody CodeRequest request) {
        
        // 1. 필수 값 체크 (userId가 없으면 즉시 실패 응답)
        if (request.getUserId() == null || request.getUserId().trim().isEmpty()) {
            return BuildResponse.builder()
                    .success(false)
                    .error("User ID is required.")
                    .build();
        }

        try {
            // 2. DockerService를 통해 코드 실행 및 결과 획득
            String result = dockerService.run(
                request.getUserId(), 
                request.getLanguage(), 
                request.getCode()
            );

            // 3. 실행 결과가 에러 메시지로 시작하는지 확인하여 응답 구성
            boolean isSuccess = !result.startsWith("Error") && !result.startsWith("Server Error");

            return BuildResponse.builder()
                    .success(isSuccess)
                    .output(isSuccess ? result : null)
                    .error(isSuccess ? null : result)
                    .build();

        } catch (Exception e) {
            // 4. 예상치 못한 예외 발생 시 처리
            return BuildResponse.builder()
                    .success(false)
                    .error("Controller Error: " + e.getMessage())
                    .build();
        }
    }
}