package com.springboot.rocky.controller;

import com.springboot.rocky.dto.CodeRequest;
import com.springboot.rocky.service.DockerService;
import lombok.RequiredArgsConstructor;
import org.springframework.web.bind.annotation.*;

/**
 * 사용자의 코드 실행 요청을 처리하는 컨트롤러입니다.
 */
@RestController
@RequestMapping("/api/v1/build")
@RequiredArgsConstructor // Lombok: 생성자 주입을 자동으로 생성
public class BuildController {

    private final DockerService dockerService;

    /**
     * 사용자가 작성한 코드를 받아 실행 결과를 반환합니다.
     * @param request (userId, language, code 포함)
     * @return 실행 결과 문자열
     */
    @PostMapping("/run")
    public String runBuild(@RequestBody CodeRequest request) {
        // 1. 요청 데이터 검증 (필요 시)
        if (request.getUserId() == null || request.getUserId().isEmpty()) {
            return "Error: User ID is required for execution.";
        }

        // 2. 서비스 레이어로 데이터 전달
        // 기존과 다르게 userId를 추가로 넘겨서 사용자별 폴더를 관리하게 합니다.
        return dockerService.run(request.getUserId(), request.getLanguage(), request.getCode());
    }
}